# Local dev: copy to .env.local (gitignored) and fill in with your own values.
# Vercel prod:  set these same keys in Project → Settings → Environment Variables
#               (for Production and Preview). Do NOT put service-role / Resend
#               keys here — those live as Supabase Edge Function secrets only.
# Anon key: Supabase Dashboard → Settings → API → Project API keys → "anon public"
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...
